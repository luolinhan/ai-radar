# AI Radar 环境变量配置

# 数据库
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ai_radar
POSTGRES_USER=ai_radar
POSTGRES_PASSWORD=your_password_here

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# AI API (Coding Plan)
AI_API_BASE_URL=https://api.codingplan.cn
AI_API_KEY=your_api_key_here
AI_MODEL=qwen3.5-plus

# GitHub
GITHUB_TOKEN=your_github_token_here

# 飞书
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_id
ALERT_SCAN_INTERVAL_MINUTES=10
ALERT_MAX_PER_RUN=3
ALERT_DEDUP_HOURS=24
ALERT_LOOKBACK_HOURS=72
ALERT_MIN_QUALITY_SCORE=4
ALERT_SIGNAL_KEYWORDS=release,launch,model,gpt,claude,gemini,open source,paper,benchmark,safety,policy,funding,acquire,partnership,chip,gpu,发布,开源,模型,安全,融资,收购,合作
DASHBOARD_PUBLIC_URL=http://localhost:3000

# 采集频率与范围
RSS_COLLECT_INTERVAL_MINUTES=120
GITHUB_COLLECT_INTERVAL_MINUTES=180
X_COLLECT_INTERVAL_MINUTES=240
WEB_COLLECT_INTERVAL_MINUTES=360
RSS_MAX_ITEMS_PER_FEED=10
GITHUB_MAX_RELEASES_PER_REPO=5
X_MAX_ITEMS_PER_ACCOUNT=5
WEB_MAX_ITEMS_PER_SITE=3
WATCH_ENTITIES_PATH=/app/configs/watchlists/entities.json
SOURCE_TARGETS_PATH=/app/configs/watchlists/source_targets.json

# 服务端口
API_PORT=8000
DASHBOARD_PORT=3000
